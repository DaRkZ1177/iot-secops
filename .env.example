# IoT SecOps — Environment Configuration
# Copy this file to .env and fill in your values

# Security — change this to a strong random string in production
SECRET_KEY=change-me-to-a-strong-random-secret

# Database — SQLite file path (relative to backend root)
DB_PATH=iot_security.db

# Security thresholds
BLOCK_DURATION=30
RATE_LIMIT=20
RATE_WINDOW=5
ANOMALY_THRESHOLD=8
ANOMALY_WINDOW=1
MQTT_RATE_LIMIT=15
MQTT_PAYLOAD_MAX=1024

# Frontend API URL (used by Vite)
VITE_API_URL=http://localhost:8000
